{
  "cleanUrls": true,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://opsai-backend.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://opsai-backend.onrender.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
