# ==================================================
# BACKEND SETTINGS
# ==================================================

# Server Config
PORT=8000
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=info

# CORS Origins (comma-separated URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# RAG Knowledge Configurations
TRADE_KNOWLEDGE_CSV=data/Kaizen_Ops_Chatbot_Dataset.csv
ANALYTICS_FILE=data/analytics.json

# LLM Providers
# Options: ollama, openai
LLM_PROVIDER=ollama
# Options: mistral, llama3.1:8b, gpt-4o-mini, llama3-8b
LLM_MODEL=tinyllama:latest
OLLAMA_URL=http://localhost:11434

# Embedding Configurations
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# Vector Database (ChromaDB)
# For in-process local storage, specify CHROMA_PATH:
CHROMA_PATH=vector_store/chromadb
# For production standalone Chroma DB server, specify CHROMA_SERVER_HOST:
CHROMA_SERVER_HOST=
CHROMA_SERVER_HTTP_PORT=8000

# OpenAI compatible API credentials (if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1


# ==================================================
# FRONTEND SETTINGS
# ==================================================

VITE_API_URL=http://localhost:8000
